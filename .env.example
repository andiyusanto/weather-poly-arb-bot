# ─── Polymarket ───────────────────────────────────────────────────────────────
# Your Polygon/Ethereum private key (hex, no 0x prefix required)
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Optional: API Key from https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# CLOB host — leave default unless using a proxy
CLOB_HOST=https://clob.polymarket.com

# Gamma API — market discovery
GAMMA_API_HOST=https://gamma-api.polymarket.com

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get your chat ID via @userinfobot or @RawDataBot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ─── Trading ──────────────────────────────────────────────────────────────────
# dry_run=true means no real orders are placed
DRY_RUN=true

# Minimum EV required to surface a trade (0.20 = 20%)
MIN_EV_THRESHOLD=0.20

# Kelly fraction (0.25 = quarter Kelly — recommended)
KELLY_FRACTION=0.25

# Maximum USDC per single trade
MAX_TRADE_USDC=50.0

# Maximum USDC across all open trades per day
DAILY_MAX_USDC=500.0

# Minimum model confidence (0–1); based on ensemble spread narrowness
MIN_CONFIDENCE=0.55

# Only trade markets resolving within this many hours
MAX_HOURS_TO_RESOLUTION=48

# ─── Market types ─────────────────────────────────────────────────────────────
# Which market categories to scan (comma-separated)
# Options: temperature, precipitation, snowfall
ENABLED_MARKET_TYPES=temperature,precipitation,snowfall

# ─── Forecast ─────────────────────────────────────────────────────────────────
# Open-Meteo ensemble models (comma-separated)
# Options: icon_seamless, gfs_seamless, ecmwf_ifs025, gem_seamless, bom_access_global_ensemble
ENSEMBLE_MODELS=icon_seamless,gfs_seamless,ecmwf_ifs025

# Number of historical days to use for bias correction (0 = disabled)
BIAS_CORRECTION_DAYS=30

# ─── Concurrency ──────────────────────────────────────────────────────────────
# Max parallel workers for forecast fetching (raise to 20-25 for 50+ cities)
# Safe default: 10. Recommended max: 25 (respects Open-Meteo rate limits)
MAX_CONCURRENCY=10

# ─── Scheduler ────────────────────────────────────────────────────────────────
# How often to scan for opportunities (minutes)
SCAN_INTERVAL_MINUTES=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
